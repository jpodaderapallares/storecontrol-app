# Variables de entorno para StoreControl
# Rellenar con los valores reales de tu proyecto Supabase antes de lanzar la app.

VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key

# Backend / Edge Functions (no se exponen al cliente, solo en supabase)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=storecontrol@tu-dominio.com
ADMIN_EMAIL=logistica@tu-dominio.com
